configuration {
    modi: "drun,run,window";
    show-icons: true;
    icon-theme: "Papirus";
    font: "Agave Nerd Font Mono 11";
    drun-display-format: "{icon} {name}";
}

* {
    bg:     #2d353b;
    bg-alt: #3a4248;
    fg:     #d3c6aa;
    selected:#a7c080;
    active: #83c092;
    urgent: #e67e80;

    background-color: @bg;
    text-color: @fg;
}

window {
    width: 600px;
    border: 2px;
    border-color: @selected;
    border-radius: 10px;
    padding: 10px;
}

inputbar {
    background-color: @bg-alt;
    border-radius: 8px;
    padding: 8px;
    margin: 0 0 10px 0;
}

listview {
    lines: 10;
    spacing: 5px;
}

element {
    padding: 8px;
    border-radius: 8px;
}

element selected.normal {
    background-color: @selected;
    text-color: #2d353b;
}

element selected.active {
    background-color: @active;
    text-color: #2d353b;
}

element selected.urgent {
    background-color: @urgent;
    text-color: #2d353b;
}

element-icon {
    size: 24px;
    margin: 0 10px 0 0;
}
