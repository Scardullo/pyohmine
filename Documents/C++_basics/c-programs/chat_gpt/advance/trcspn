#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include "student.h"

// Forward declarations for functions used before their definition
void freeList();

// Global variables
Student *head = NULL;
static Student *lastDeleted = NULL;  // For undo

// ==================== GET NEXT ID ====================
int getNextId() {
    int maxId = 0;
    Student *temp = head;
    while (temp) {
        if (temp->id > maxId)
            maxId = temp->id;
        temp = temp->next;
    }
    return maxId + 1;
}

// ==================== ADD STUDENT ====================
void addStudent() {
    Student *newStudent = malloc(sizeof(Student));
    if (!newStudent) {
        printf("Memory allocation failed!\n");
        return;
    }

    newStudent->id = getNextId();
    getchar(); // consume newline
    printf("Enter name: ");
    fgets(newStudent->name, sizeof(newStudent->name), stdin);
    newStudent->name[strcspn(newStudent->name, "\n")] = '\0';

    printf("Enter grade: ");
    scanf("%f", &newStudent->grade);

    newStudent->next = head;
    head = newStudent;

    printf("Student added successfully (ID: %d)\n", newStudent->id);
    saveToCSV();
}

// ==================== DISPLAY ====================
void displayStudents() {
    if (!head) {
        printf("No student records found.\n");
        return;
    }
    printf("\n%-5s %-20s %-6s\n", "ID", "Name", "Grade");
    for (Student *t = head; t; t = t->next)
        printf("%-5d %-20s %-6.2f\n", t->id, t->name, t->grade);
}

// ==================== SEARCH ====================
void searchById() {
    int id;
    printf("Enter ID: ");
    scanf("%d", &id);
    for (Student *t = head; t; t = t->next)
        if (t->id == id) {
            printf("Found: %d | %s | %.2f\n", t->id, t->name, t->grade);
            return;
        }
    printf("Student not found.\n");
}

void searchByName() {
    getchar(); // consume newline
    char keyword[50];
    printf("Enter name keyword: ");
    fgets(keyword, sizeof(keyword), stdin);
    keyword[strcspn(keyword, "\n")] = '\0';

    int found = 0;
    for (Student *t = head; t; t = t->next)
        if (strstr(t->name, keyword)) {
            printf("%d | %s | %.2f\n", t->id, t->name, t->grade);
            found = 1;
        }
    if (!found) printf("No matches found.\n");
}

// ==================== DELETE ====================
void deleteStudent() {
    int id;
    printf("Enter ID to delete: ");
    scanf("%d", &id);

    Student *t = head, *prev = NULL;
    while (t && t->id != id) {
        prev = t;
        t = t->next;
    }
    if (!t) {
        printf("ID not found.\n");
        return;
    }

    if (prev) prev->next = t->next;
    else head = t->next;

    free(lastDeleted);
    lastDeleted = malloc(sizeof(Student));
    *lastDeleted = *t;

    free(t);
    printf("Student deleted.\n");
    saveToCSV();
}

// ==================== UNDO DELETE ====================
void undoLastDelete() {
    if (!lastDeleted) {
        printf("No recent deletion to undo.\n");
        return;
    }

    Student *undo = malloc(sizeof(Student));
    *undo = *lastDeleted;
    undo->next = head;
    head = undo;

    printf("Undo successful: Restored %s (%.2f)\n", undo->name, undo->grade);
    free(lastDeleted);
    lastDeleted = NULL;
    saveToCSV();
}

// ==================== EDIT ====================
void editStudent() {
    int id;
    printf("Enter ID to edit: ");
    scanf("%d", &id);
    getchar();

    Student *t = head;
    while (t && t->id != id) t = t->next;
    if (!t) {
        printf("Student not found.\n");
        return;
    }

    char choice;
    printf("Editing %s (%.2f)\n", t->name, t->grade);
    printf("Change name? (y/n): ");
    scanf(" %c", &choice); getchar();
    if (choice == 'y' || choice == 'Y') {
        printf("Enter new name: ");
        fgets(t->name, sizeof(t->name), stdin);
        t->name[strcspn(t->name, "\n")] = '\0';
    }

    printf("Change grade? (y/n): ");
    scanf(" %c", &choice);
    if (choice == 'y' || choice == 'Y') {
        printf("Enter new grade: ");
        scanf("%f", &t->grade);
    }

    printf("Student updated.\n");
    saveToCSV();
}

// ==================== SAVE / LOAD ====================
void saveToCSV() {
    FILE *fp = fopen(FILE_NAME, "w");
    if (!fp) return;
    fprintf(fp, "ID,Name,Grade\n");
    for (Student *t = head; t; t = t->next)
        fprintf(fp, "%d,%s,%.2f\n", t->id, t->name, t->grade);
    fclose(fp);
}

void loadFromCSV() {
    FILE *fp = fopen(FILE_NAME, "r");
    if (!fp) return;

    freeList(); // free existing data before loading

    char line[128];
    fgets(line, sizeof(line), fp); // skip header
    while (fgets(line, sizeof(line), fp)) {
        Student *n = malloc(sizeof(Student));
        if (sscanf(line, "%d,%49[^,],%f", &n->id, n->name, &n->grade) == 3) {
            n->next = head;
            head = n;
        } else free(n);
    }
    fclose(fp);
}

// ==================== EXPORT TO JSON ====================
void exportToJSON() {
    FILE *fp = fopen(JSON_FILE, "w");
    if (!fp) {
        printf("Could not open JSON file.\n");
        return;
    }
    fprintf(fp, "[\n");
    Student *t = head;
    while (t) {
        fprintf(fp, "  {\"id\": %d, \"name\": \"%s\", \"grade\": %.2f}%s\n",
                t->id, t->name, t->grade, t->next ? "," : "");
        t = t->next;
    }
    fprintf(fp, "]\n");
    fclose(fp);
    printf("Data exported to %s\n", JSON_FILE);
}

// ==================== SORT HELPERS ====================
static Student *mergeByName(Student *a, Student *b) {
    if (!a) return b;
    if (!b) return a;
    if (strcmp(a->name, b->name) < 0) {
        a->next = mergeByName(a->next, b);
        return a;
    } else {
        b->next = mergeByName(a, b->next);
        return b;
    }
}

static Student *mergeByGrade(Student *a, Student *b) {
    if (!a) return b;
    if (!b) return a;
    if (a->grade > b->grade) {
        a->next = mergeByGrade(a->next, b);
        return a;
    } else {
        b->next = mergeByGrade(a, b->next);
        return b;
    }
}

static void frontBackSplit(Student *source, Student **front, Student **back) {
    if (!source || !source->next) {
        *front = source;
        *back = NULL;
        return;
    }
    Student *slow = source, *fast = source->next;
    while (fast) {
        fast = fast->next;
        if (fast) {
            slow = slow->next;
            fast = fast->next;
        }
    }
    *front = source;
    *back = slow->next;
    slow->next = NULL;
}

static void mergeSort(Student **headRef, int byGrade) {
    Student *h = *headRef;
    if (!h || !h->next) return;
    Student *a, *b;
    frontBackSplit(h, &a, &b);
    mergeSort(&a, byGrade);
    mergeSort(&b, byGrade);
    *headRef = byGrade ? mergeByGrade(a, b) : mergeByName(a, b);
}

void sortStudentsByName() {
    mergeSort(&head, 0);
    printf("Sorted by name.\n");
    saveToCSV();
}

void sortStudentsByGrade() {
    mergeSort(&head, 1);
    printf("Sorted by grade.\n");
    saveToCSV();
}

// ==================== STATISTICS ====================
float getAverageGrade() {
    if (!head) return 0;
    int count = 0;
    float total = 0;
    for (Student *t = head; t; t = t->next) {
        total += t->grade;
        count++;
    }
    return count ? total / count : 0;
}

Student *getTopStudent() {
    if (!head) return NULL;
    Student *top = head;
    for (Student *t = head->next; t; t = t->next)
        if (t->grade > top->grade)
            top = t;
    return top;
}

Student *getLowestStudent() {
    if (!head) return NULL;
    Student *low = head;
    for (Student *t = head->next; t; t = t->next)
        if (t->grade < low->grade)
            low = t;
    return low;
}

// ==================== FREE LIST ====================
void freeList() {
    Student *t;
    while (head) {
        t = head;
        head = head->next;
        free(t);
    }
}
